rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin kontrolü
    function isAdmin() {
      return request.auth != null && request.auth.token.email == "yukluberkay@gmail.com";
    }

    // Giriş yapmış kullanıcı
    function isLoggedIn() {
      return request.auth != null;
    }

    // Abone kullanıcı
    function isSubscribed() {
      return isLoggedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isSubscribed == true;
    }

    // GÖNDERILER
    match /posts/{postId} {
      allow read: if true; // Herkes okuyabilir (premium kontrolü frontend'de)
      allow create, update, delete: if isAdmin();

      // Yorumlar
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isLoggedIn();
        allow update: if isLoggedIn() && (
          request.auth.uid == resource.data.userId ||
          isAdmin() ||
          // Beğeni sayısını güncelleyebilir
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes','likedBy'])
        );
        allow delete: if isLoggedIn() && (request.auth.uid == resource.data.userId || isAdmin());
      }
    }

    // KULLANICILAR
    match /users/{userId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn() && request.auth.uid == userId;
      allow update: if isLoggedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // KISAYOLLAR
    match /shortcuts/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // PLANLAR
    match /plans/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ÖDEMELER
    match /payments/{id} {
      allow read: if isAdmin() || (isLoggedIn() && resource.data.userId == request.auth.uid);
      allow create: if isLoggedIn();
      allow update, delete: if isAdmin();
    }

    // AYARLAR
    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // MESAJLAR (iletişim formu)
    match /messages/{id} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // SSS
    match /faq/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
